{
  "name": "@surfrock/sdk",
  "version": "2.0.0",
  "description": "Surfrock SDK",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "tsc",
    "check:all": "npm run clean && npm run build && npm test",
    "clean": "rimraf ./lib \"npm-debug.log*\" ./docs ./coverage ./.nyc_output",
    "coverage": "vitest run --coverage",
    "test": "npm run eslint && npm run coverage",
    "eslint": "eslint src/**/*.ts",
    "preversion": "npm run check:all",
    "version": "git add -A",
    "postversion": "git push origin --tags",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/surfrock/sdk.git"
  },
  "author": {
    "name": "Motionpicture co.,ltd."
  },
  "contributors": [
    {
      "email": "yamazaki@motionpicture.jp",
      "name": "Tetsu Yamazaki"
    }
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/debug": "4.1.13",
    "@types/node": "22.19.15",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/ui": "4.1.4",
    "eslint": "9.39.4",
    "nock": "14.0.7",
    "redis": "4.7.0",
    "rimraf": "^2.6.2",
    "typescript": "5.6.3",
    "typescript-eslint": "8.58.0",
    "undici": "7.24.6",
    "vitest": "4.1.4"
  },
  "dependencies": {
    "@surfrock/factory": "1.0.0",
    "debug": "4.4.3"
  }
