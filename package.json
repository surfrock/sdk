{
  "name": "@surfrock/sdk",
  "version": "1.4.0-alpha.1",
  "description": "Surfrock SDK",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "docs",
    "example",
    "lib"
  ],
  "directories": {
    "doc": "./docs",
    "lib": "./lib",
    "example": "./example",
    "test": "./test"
  },
  "scripts": {
    "build": "tsc",
    "check": "npm run tslint",
    "clean": "rimraf ./lib \"npm-debug.log*\" ./docs ./coverage ./.nyc_output",
    "doc": "echo \"implementing...\" && exit 0",
    "mocha": "mocha",
    "nyc": "nyc mocha \"src/**/*.spec.ts\"",
    "coverage": "npm run nyc && nyc report --reporter=text-lcov | coveralls",
    "test": "npm run check && npm run coverage",
    "tslint": "tslint --project tsconfig.json -c tslint.json --exclude \"**/*.spec.ts\" \"src/**/*.ts\"",
    "preversion": "npm run clean && npm run build && npm test && npm run doc",
    "version": "git add -A",
    "postversion": "git push origin --tags",
    "prepublishOnly": "npm run clean && npm run build && npm test && npm run doc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/surfrock/sdk.git"
  },
  "author": {
    "name": "Motionpicture co.,ltd."
  },
  "contributors": [
    {
      "email": "yamazaki@motionpicture.jp",
      "name": "Tetsu Yamazaki"
    }
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/debug": "0.0.30",
    "@types/fetch-mock": "6.0.9",
    "@types/http-status": "1.1.2",
    "@types/isomorphic-fetch": "0.0.39",
    "@types/mocha": "^5.2.5",
    "@types/node": "18.19.31",
    "@types/power-assert": "^1.5.0",
    "@types/qs": "6.5.3",
    "@types/sinon": "^5.0.5",
    "coveralls": "^3.0.2",
    "fetch-mock": "6.5.2",
    "mocha": "^5.2.0",
    "moment": "^2.22.2",
    "nock": "13.5.4",
    "nyc": "15.1.0",
    "power-assert": "^1.6.1",
    "redis": "4.7.0",
    "rimraf": "^2.6.2",
    "sinon": "^6.3.5",
    "ts-node": "^7.0.1",
    "tslint": "^5.11.0",
    "tslint-microsoft-contrib": "^5.2.1",
    "typescript": "5.0.3"
  },
  "dependencies": {
    "@surfrock/soap-parser": "2.0.0",
    "abort-controller": "3.0.0",
    "debug": "3.2.7",
    "http-status": "1.6.2",
    "isomorphic-fetch": "3.0.0",
    "qs": "6.5.3"
  }
}
